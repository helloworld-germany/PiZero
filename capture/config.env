# PiZero Capture – Environment Configuration
# Copy this file and adjust values for your deployment.

# Backend API base URL (the same vidaugment Azure Functions host)
VIDAUGMENT_API_BASE_URL=https://vidaugment-ingest-prod.azurewebsites.net

# Recording / chunk duration in seconds (each chunk is this long)
RECORD_DURATION_S=20

# Hard session timeout (seconds) – failsafe, 30 minutes
HARD_TIMEOUT_S=1800

# High-performance capture resolution
VIDEO_WIDTH=720
VIDEO_HEIGHT=1280
VIDEO_FPS=30

# QR scanner (fast scan mode)
QR_SCAN_WIDTH=480
QR_SCAN_HEIGHT=480
QR_SCAN_FPS=15

# ALSA audio device – run `arecord -l` to find yours
AUDIO_DEVICE=default
AUDIO_SAMPLE_RATE=44100

# Software volume boost in dB (INMP441 is very quiet, 30dB matches phone level)
# Set to 0 to disable. Adjust if audio clips or is still too quiet.
AUDIO_GAIN_DB=30

# Audio backend: "auto", "alsa", or "i2s"
AUDIO_BACKEND=i2s

# I2S microphone (INMP441 via googlevoicehat-soundcard overlay)
USE_I2S_MIC=true
I2S_AUDIO_DEVICE=hw:0,0

# Temporary capture directory
CAPTURE_DIR=/tmp/picapture

# GPIO pin for status LED (BCM numbering)
LED_PIN=17

# ---------------------------------------------------------------------------
# Optional hardware board
# ---------------------------------------------------------------------------

# Push button (BCM 3 / physical pin 5)
USE_BUTTON=false
BUTTON_PIN=3
BUTTON_ACTIVE_LOW=true

# Piezo buzzer (BCM 23 / physical pin 16)
# NOTE: GPIO18 is avoided because it may be used by I2S BCLK.
USE_BUZZER=true
BUZZER_PIN=23
BUZZER_PWM=true
BUZZER_FREQUENCY=1000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
